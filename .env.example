# Public HTTPS base URL of the AICO backend (origin + tenant path prefix).
# NOTE: the Shopify CLI does NOT read this file — the value must be a real
# shell env var at build/deploy time. Use the pnpm scripts (pnpm deploy etc.),
# which source .env before invoking the CLI.
# Production: https://aicoapp.aico.swiss/<workspace external id>
# Local dev:  the cloudflared quick tunnel exposing sail (ephemeral URL).
AICO_API_ORIGIN="https://aicoapp.aico.swiss/83641"
